FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pimpleFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime   	    100;

deltaT          0.001;

writeControl    runTime;

writeInterval   0.2;

purgeWrite      0;

writeFormat     binary;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   8;

runTimeModifiable no;

adjustTimeStep  no;

maxCo           1;

functions
{
    #includeFunc forceCoeffs
    #includeFunc probes
    #includeFunc flowRateJet1
    #includeFunc flowRateJet2
    #includeFunc preCICE_Adapter
}

